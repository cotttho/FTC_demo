#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"
mkdir -p reports

STAMP="$(date +%Y%m%d-%H%M%S)"
LOG="reports/ftc-report-handoff-${STAMP}.log"
CISCO_VPN_HOST="${CISCO_VPN_HOST:-}"
RESTORE_SSID="${RESTORE_SSID:-}"
WORKDIR="$PWD"

nohup bash -c '
  set -euo pipefail
  workdir="$1"
  log="$2"
  cisco_host="$3"
  restore_ssid="$4"
  cd "$workdir"
  sleep 3
  printf "FTC report handoff started: %s\n" "$(date)"
  printf "Log: %s\n" "$log"
  CISCO_SECURE_CLIENT=1 \
  CISCO_VPN_HOST="$cisco_host" \
  RESTORE_SSID="$restore_ssid" \
  ./ftc-net-run -- ./collect-ftc-report
  printf "FTC report handoff completed: %s\n" "$(date)"
' bash "$WORKDIR" "$LOG" "$CISCO_VPN_HOST" "$RESTORE_SSID" >>"$LOG" 2>&1 &

PID="$!"
printf 'Started FTC report handoff in background.\n'
printf 'PID: %s\n' "$PID"
printf 'Log: %s\n' "$LOG"
printf 'Latest report symlink/copy target: reports/latest-ftc-report.md\n'
