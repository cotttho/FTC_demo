printf '\n[1/4] Crawling Control Hub web console\n'
python3 - "$FTC_URL" "$OUTDIR/http" <<'PY'
import html.parser
import json
import re
import sys
import time
import urllib.error
import urllib.parse
import urllib.request
from pathlib import Path

base_url = sys.argv[1]
outdir = Path(sys.argv[2])
outdir.mkdir(parents=True, exist_ok=True)

parsed_base = urllib.parse.urlparse(base_url)
origin = f"{parsed_base.scheme}://{parsed_base.netloc}"

initial_paths = [
    "/",
    "/manage",
    "/inspection",
    "/inspect",
    "/java",
    "/blocks",
    "/programming",
    "/config",
    "/configuration",
    "/configurations",
    "/hardware",
    "/server",
    "/server/status",
    "/status",
    "/ping",
    "/robots.txt",
]

class LinkParser(html.parser.HTMLParser):
    def __init__(self):
        super().__init__()
        self.links = []

    def handle_starttag(self, tag, attrs):
        for key, value in attrs:
            if key.lower() in {"href", "src", "action"} and value:
                self.links.append(value)

def safe_name(index, url):
    parsed = urllib.parse.urlparse(url)
    path = parsed.path or "/"
    name = path.strip("/").replace("/", "__") or "root"
    if parsed.query:
        name += "__" + re.sub(r"[^A-Za-z0-9_.-]+", "_", parsed.query)[:80]
    name = re.sub(r"[^A-Za-z0-9_.-]+", "_", name)
    return f"{index:03d}_{name}"

def normalize(candidate):
    if not candidate:
        return None
    url = urllib.parse.urljoin(origin + "/", candidate)
    parsed = urllib.parse.urlparse(url)
    if parsed.scheme not in {"http", "https"}:
        return None
    if parsed.netloc != parsed_base.netloc:
        return None
    return urllib.parse.urlunparse((parsed.scheme, parsed.netloc, parsed.path or "/", "", parsed.query, ""))

queue = []
seen = set()
for path in initial_paths:
    url = normalize(path)
    if url and url not in seen:
        seen.add(url)
        queue.append(url)

inventory = []
index = 0
while queue and index < 80:
    url = queue.pop(0)
    index += 1
    item = {
        "index": index,
        "url": url,
        "ok": False,
        "status": None,
        "content_type": "",
        "body_file": None,
        "error": None,
    }
    name = safe_name(index, url)
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "ftc-report-collector/1.0"})
        with urllib.request.urlopen(req, timeout=5) as resp:
            body = resp.read(2_000_000)
            headers = dict(resp.headers.items())
            item["ok"] = 200 <= resp.status < 400
            item["status"] = resp.status
            item["content_type"] = resp.headers.get("Content-Type", "")
            item["body_file"] = f"{name}.body"
            (outdir / f"{name}.headers.json").write_text(json.dumps(headers, indent=2), encoding="utf-8")
            (outdir / f"{name}.body").write_bytes(body)

        text = body.decode("utf-8", errors="ignore")
        if "html" in item["content_type"].lower() or "<html" in text[:500].lower():
            parser = LinkParser()
            parser.feed(text)
            candidates = parser.links
            candidates += re.findall(r"""["'](/[^"'<> ]+)["']""", text)
            for link in candidates:
                next_url = normalize(link)
                if next_url and next_url not in seen:
                    seen.add(next_url)
                    queue.append(next_url)
    except urllib.error.HTTPError as exc:
        item["status"] = exc.code
        item["error"] = str(exc)
        try:
            body = exc.read(200_000)
            item["body_file"] = f"{name}.body"
            (outdir / f"{name}.body").write_bytes(body)
        except Exception:
            pass
    except Exception as exc:
        item["error"] = repr(exc)

    inventory.append(item)
    time.sleep(0.05)

(outdir / "inventory.json").write_text(json.dumps(inventory, indent=2), encoding="utf-8")
ok_count = sum(1 for item in inventory if item["ok"])
print(f"Fetched {len(inventory)} console URLs; {ok_count} returned 2xx/3xx.")
PY

